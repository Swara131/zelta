# =============================================================================
# Supabase (required)
# =============================================================================
#
# 1. Copy this file to .env.local in the SAME folder as package.json:
#      cp .env.example .env.local        (macOS/Linux)
#      copy .env.example .env.local      (Windows)
#
# 2. Open your Supabase project dashboard:
#      https://supabase.com/dashboard
#
# 3. Go to: Project Settings → API
#      https://supabase.com/dashboard/project/_/settings/api
#
# 4. Paste the values below:
#      - Project URL        → NEXT_PUBLIC_SUPABASE_URL
#      - anon public key      → NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# 5. Restart the dev server after saving .env.local:
#      npm run dev
#
# Security: Use the anon (public) key only. Never commit .env.local.
# Do NOT put the service_role key in NEXT_PUBLIC_* variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database: run SQL migrations in supabase/migrations/ (see supabase/README.md)

# Auth setup: see lib/auth/README.md
# Enable Email + Google in Supabase Dashboard → Authentication → Providers
# Redirect URLs: http://localhost:3000/auth/callback
#                  http://localhost:3000/auth/reset-password

# =============================================================================
# Groq (required for AI Translator + Risk Analysis)
# =============================================================================
#
# Get an API key: https://console.groq.com/keys
#
# GROQ_MODEL is optional (defaults to llama-3.3-70b-versatile).

GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# =============================================================================
# Resend (email notifications)
# =============================================================================
#
# Get an API key: https://resend.com/api-keys
# Verify your sending domain in Resend dashboard.
# FROM must use a verified domain (or Resend sandbox for testing).

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=ApprovalLayer <notifications@yourdomain.com>

# Public app URL for email CTA links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: secret for batch retry cron (POST /api/notifications/retry)
# Authorization: Bearer YOUR_SECRET
# NOTIFICATION_RETRY_SECRET=your-cron-secret

# =============================================================================
# Stripe (subscriptions & billing)
# =============================================================================
#
# Dashboard: https://dashboard.stripe.com/
# 1. Create products/prices for Professional (monthly + yearly)
# 2. Enable Customer Portal in Settings → Billing → Customer portal
# 3. Add webhook endpoint: https://YOUR_DOMAIN/api/webhooks/stripe
#    Events: checkout.session.completed, customer.subscription.*, invoice.payment_failed
# 4. For local webhooks: stripe listen --forward-to localhost:3000/api/webhooks/stripe
#
# SUPABASE_SERVICE_ROLE_KEY is required for webhook sync (server-only, never expose to client).

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_professional_monthly
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_professional_yearly
# Optional enterprise self-serve prices (default: contact sales only)
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly
# STRIPE_PRICE_ENTERPRISE_YEARLY=price_enterprise_yearly

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# PayPal (subscriptions & billing webhooks)
# =============================================================================
#
# Developer dashboard: https://developer.paypal.com/dashboard/
# 1. Create a REST app (sandbox or live) for CLIENT_ID / CLIENT_SECRET
# 2. Create a subscription plan and set custom_id to organization UUID at subscribe time
# 3. Add webhook: https://YOUR_DOMAIN/api/paypal/webhook
#    Events: BILLING.SUBSCRIPTION.ACTIVATED, CANCELLED, SUSPENDED, EXPIRED, PAYMENT.FAILED
# 4. Copy the Webhook ID from the PayPal dashboard
#
# Optional plan mapping (filled in by npm run paypal:create-plans):
# PAYPAL_PRODUCT_ID=PROD-...
# PAYPAL_PLAN_PROFESSIONAL_MONTHLY=P-...
# PAYPAL_PLAN_PROFESSIONAL_YEARLY=P-...

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_ENVIRONMENT=sandbox

# Optional pepper for agent API key hashing (server-only, never expose to client)
# GATEWAY_API_KEY_PEPPER=your-long-random-pepper
# Optional separate pepper for execution token hashing (falls back to GATEWAY_API_KEY_PEPPER)
# GATEWAY_EXECUTION_TOKEN_PEPPER=your-long-random-pepper

# Gateway risk enforcement (default: shadow — observational only)
# RISK_ENFORCEMENT_MODE=shadow|enforce|hybrid
# When enforce + classifier unavailable: preserve (default) or review
# RISK_FAILSAFE_ON_UNAVAILABLE=preserve|review
# Hybrid mode: escalate ALLOW→REVIEW only for high/critical when confidence >= threshold (default 0.7)
# RISK_HYBRID_CONFIDENCE_THRESHOLD=0.7

# Review deadline for pending human review (default: 4 hours, auto-deny on timeout)
# REVIEW_DEADLINE_HOURS=4
# REVIEW_TIMEOUT_BEHAVIOR=auto_deny|escalate
# REVIEW_ESCALATION_MAX_LEVEL=3

# =============================================================================
# Demo agent (scripts/demo-agent.ts) — local or hosted gateway
# =============================================================================
#
# 1. Create an agent API key at {APPROVALAYER_API_URL}/integrations (admin required)
# 2. AGENT_ID must match the agent id bound to that key
#
# Local:
#   APPROVALAYER_API_URL=http://localhost:3000
#   AGENT_API_KEY=al_your_plaintext_key_shown_once
#   AGENT_ID=demo-refund-agent
#   npm run demo:agent -- allow|review|block|all
#
# Hosted (Vercel/production):
#   APPROVALAYER_API_URL=https://your-app.vercel.app
#   AGENT_API_KEY=al_...
#   AGENT_ID=demo-refund-agent
#   npm run demo:agent -- review
#
# Optional tuning:
#   DEMO_POLL_INTERVAL_MS=5000
#   DEMO_POLL_TIMEOUT_MS=300000

# =============================================================================
# Demo mode (optional — unlocks Enterprise feature access for all users)
# =============================================================================
#
# When DEMO_MODE=true, premium features and usage limits are bypassed for
# authenticated users. Database subscriptions and Stripe are unchanged.
# Set DEMO_MODE=false or omit it for normal production billing enforcement.
#
# DEMO_MODE=true

# =============================================================================
# Security
# =============================================================================
#
# NOTIFICATION_RETRY_SECRET — bearer token for POST /api/notifications/retry
# Use a long random string (32+ chars). Never expose to the client.
#
# NOTIFICATION_RETRY_SECRET=your-long-random-cron-secret
#
# Production checklist:
# - Set NODE_ENV=production on deploy
# - Use HTTPS only (HSTS enabled automatically in production)
# - Apply migration 20260701180000_security_hardening.sql
# - Configure Stripe webhook signing secret
# - Never commit .env.local or service role keys
